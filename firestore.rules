
rules_version = '2';

// Firestore security rules are currently configured to be open for development.
// All access control is managed within the application's client-side logic.
// This configuration is NOT recommended for production environments.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
