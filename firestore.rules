
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function getUserData(userId) {
      // Returns the resource object, not just the data, to allow for null checks
      return get(/databases/$(database)/documents/users/$(userId));
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin(userId) {
      let userRes = getUserData(userId);
      return userRes != null && 'role' in userRes.data && userRes.data.role == 'Administrator';
    }

    function isManager(userId) {
      let userRes = getUserData(userId);
      return userRes != null && 'role' in userRes.data && userRes.data.role == 'Manager';
    }

    function isExecutive(userId) {
      let userRes = getUserData(userId);
      return userRes != null && 'role' in userRes.data && userRes.data.role == 'Executive';
    }
    
    function isExecutiveWithPermission(userId, departmentId) {
      let userRes = getUserData(userId);
      if (userRes == null || !('data' in userRes) || departmentId == null) {
        return false;
      }
      let userProfile = userRes.data;

      // Check if the user is an Executive
      let isExecRole = 'role' in userProfile && userProfile.role == 'Executive';
      if (!isExecRole) {
        return false;
      }
      
      // Now check department permissions. If no approvableDepartmentIds are set, they can approve all.
      return (!('approvableDepartmentIds' in userProfile) ||
              userProfile.approvableDepartmentIds == null ||
              departmentId in userProfile.approvableDepartmentIds);
    }

    function isProcurementOfficer(userId) {
      let userRes = getUserData(userId);
      return userRes != null && 'role' in userRes.data &&
             (userRes.data.role == 'Procurement Officer' || userRes.data.role == 'Procurement Assistant');
    }
    
    function isRequester(userId) {
      let userRes = getUserData(userId);
      return userRes != null && 'role' in userRes.data && userRes.data.role == 'Requester';
    }
    
    function getDepartmentIdForUser(userId) {
        let userRes = getUserData(userId);
        if (userRes != null && 'departmentId' in userRes.data) {
            return userRes.data.departmentId;
        }
        return null;
    }

    // A function to check if a user is authorized to approve a given request,
    // either directly or because they are a higher-level approver.
    function isAllowedToApprove(userId, requestData) {
      let userRes = getUserData(userId);
      // Check if user profile exists before proceeding
      if (userRes == null || !('data' in userRes)) {
        return false;
      }
      let userProfile = userRes.data;

      let isRequestManager = ('role' in userProfile && userProfile.role == 'Manager') && userProfile.departmentId == requestData.departmentId;
      let isRequestExecutive = isExecutiveWithPermission(userId, requestData.departmentId);

      // An Executive can approve a request at the Manager stage.
      if (requestData.status == 'Pending Manager Approval' || requestData.status == 'Queries Raised') {
        return isRequestManager || isRequestExecutive;
      }
      // Only an Executive can approve at the Executive stage.
      if (requestData.status == 'Pending Executive') {
        return isRequestExecutive;
      }
      
      return false;
    }
    
    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isAdmin(request.auth.uid);
      allow update: if isAdmin(request.auth.uid) || isOwner(userId);
      allow delete: if isAdmin(request.auth.uid);
    }

    // Admins can manage roles, companies, approval groups, and app metadata
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(request.auth.uid);
    }
    
    match /companies/{companyId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(request.auth.uid);
    }
    
    match /approvalGroups/{groupId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(request.auth.uid);
    }

    match /app/metadata {
      allow read: if request.auth != null;
      allow write: if isAdmin(request.auth.uid);
    }
    
    match /departments/{departmentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(request.auth.uid);
    }

    // Procurement Requests have complex rules
    match /procurementRequests/{procurementRequestId} {
      // Allow reading a single document if you are involved with it. `resource.data` is available here.
      allow get: if request.auth != null && (
                   isAdmin(request.auth.uid)
                   || isProcurementOfficer(request.auth.uid)
                   || isExecutiveWithPermission(request.auth.uid, resource.data.departmentId)
                   || resource.data.submittedById == request.auth.uid
                   || ((isManager(request.auth.uid) || isRequester(request.auth.uid)) && resource.data.departmentId == getDepartmentIdForUser(request.auth.uid))
                 );
    
      // Allow querying the collection for any authenticated user.
      // This relies on client-side queries to correctly filter data for the user's role.
      // This is necessary because security rules cannot enforce document content-based filters for list operations.
      allow list: if request.auth != null;

      allow create: if request.auth != null && request.resource.data.status == 'Draft' && request.resource.data.submittedById == request.auth.uid;

      // Who can update? A user can update if any of the following are true:
      allow update: if
        // 1. User is an Administrator.
        isAdmin(request.auth.uid)

        // 2. User is the original submitter and the request is a Draft or has Queries.
        || (resource.data.submittedById == request.auth.uid &&
            (resource.data.status == 'Draft' || resource.data.status == 'Queries Raised'))

        // 3. User is directly authorized to approve the current stage.
        || isAllowedToApprove(request.auth.uid, resource.data)

        // 4. User is acting as a delegate for an authorized approver.
        || (request.resource.data.delegatorIdForApproval != null &&
            getUserData(request.resource.data.delegatorIdForApproval) != null &&
            getUserData(request.resource.data.delegatorIdForApproval).data.delegatedToId == request.auth.uid &&
            isAllowedToApprove(request.resource.data.delegatorIdForApproval, resource.data))

        // 5. User is a Procurement Officer and the request is in a fulfillment stage.
        || (isProcurementOfficer(request.auth.uid) &&
            (resource.data.status == 'Approved' || resource.data.status == 'In Fulfillment'));

      allow delete: if isAdmin(request.auth.uid);
    }

    // Recurring Items
    match /recurringItems/{itemId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(request.auth.uid) || isProcurementOfficer(request.auth.uid) || isManager(request.auth.uid) || isRequester(request.auth.uid);
    }

    // Vendors
    match /vendors/{vendorId} {
      allow read: if request.auth != null;
      allow write: if isAdmin(request.auth.uid) || isProcurementOfficer(request.auth.uid);
    }
    
    // Budget Data
    match /budgetUploads/{uploadId} {
      allow read, write: if isAdmin(request.auth.uid) || isProcurementOfficer(request.auth.uid);
    }
    match /budgets/{budgetId} {
      allow read, write: if isAdmin(request.auth.uid) || isProcurementOfficer(request.auth.uid);
    }

    // Logs can only be written by the app/user, and only read by Admins.
    match /auditLogs/{logId} {
      allow read: if isAdmin(request.auth.uid);
      allow create: if request.auth != null;
    }
    
    match /errorLogs/{errorLogId} {
      allow read: if isAdmin(request.auth.uid);
      allow create: if request.auth != null;
    }
    
    match /_diagnostics/{docId} {
      allow write: if request.auth != null;
    }
  }
}
