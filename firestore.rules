rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'Administrator';
    }

    // Rules for collections
    match /app/metadata {
      // Allow anyone to read this document to check if an admin is set up.
      // This is safe as it only contains a boolean flag.
      allow read: if true;
      
      // Secure the write operation. Only allow it to be created if it doesn't exist,
      // and only allow it to be set to `true`.
      allow write: if isSignedIn() && (!exists(path(resource.id)) || request.resource.data.adminIsSetUp == true);
    }
    
    match /users/{userId} {
      // Allow any signed-in user to read/list for easier initial setup.
      // For production, you should restrict this to admins or based on relationships.
      allow read, list: if isSignedIn();

      // Allow any signed-in user to create user documents during setup.
      // For production, this should be restricted to an admin-only Cloud Function.
      allow create: if isSignedIn();

      // Allow user to update their own profile, or if user is an admin
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins should delete users
      allow delete: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /vendors/{vendorId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || getRole() == 'Procurement Officer';
    }

    match /recurringItems/{recurringItemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || getRole() == 'Procurement Officer' || getRole() == 'Manager';
    }
    
    match /auditLogs/{logId} {
      // Only admins can read the audit log
      allow read: if isAdmin();
      // Any signed in user can create log entries (via app logic)
      // This should be locked down further with cloud functions in a real app
      allow create: if isSignedIn();
    }
    
    match /budgets/{budgetId} {
      allow read, write: if isAdmin() || getRole() == 'Procurement Officer';
    }

    match /procurementRequests/{requestId} {
      // Anyone involved in the request can read it. Admins, Executives, and POs can read all.
      allow get: if isSignedIn() && (
        isOwner(resource.data.submittedById) ||
        getRole() == 'Administrator' ||
        getRole() == 'Executive' ||
        getRole() == 'Procurement Officer' ||
        (getRole() == 'Manager' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department == resource.data.department)
      );
      
      // Broader list access for main pages
      allow list: if isSignedIn();

      // Users can create their own requests.
      allow create: if isOwner(request.resource.data.submittedById);
      
      // Rules for updating requests based on role and status
      allow update: if isSignedIn() && (
        isAdmin() ||
        getRole() == 'Executive' ||
        // Managers can approve for their department
        (getRole() == 'Manager' && request.resource.data.department == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department && resource.data.status == 'Pending Manager Approval') ||
        // POs can move it to fulfillment
        (getRole() == 'Procurement Officer' && resource.data.status == 'Approved') ||
        // POs and assistants can update items during fulfillment
        ((getRole() == 'Procurement Officer' || getRole() == 'Procurement Assistant') && resource.data.status == 'In Fulfillment')
      );
    }
  }
}
