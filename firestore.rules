
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function isUserRole(userId, role) {
        let userRes = getUserData(userId);
        return userRes != null && userRes.data.role == role;
    }

    function isAdmin() {
      return isUserRole(request.auth.uid, 'Administrator');
    }

    function isManager(userId) {
      return isUserRole(userId, 'Manager');
    }

    function isExecutive(userId) {
      return isUserRole(userId, 'Executive');
    }
    
    function isExecutiveWithPermission(userId, departmentId) {
      let userRes = getUserData(userId);
      if (userRes == null || departmentId == null) {
        return false;
      }
      let userProfile = userRes.data;

      if (userProfile.role != 'Executive') {
        return false;
      }
      
      // If approvableDepartmentIds is not set or is empty, they can approve all.
      if (!('approvableDepartmentIds' in userProfile) || userProfile.approvableDepartmentIds == null || userProfile.approvableDepartmentIds.size() == 0) {
        return true;
      }
      
      // If the array exists and is not empty, check if the departmentId is in it.
      return departmentId in userProfile.approvableDepartmentIds;
    }

    function isProcurementOfficer(userId) {
      let userRes = getUserData(userId);
      return userRes != null && (userRes.data.role == 'Procurement Officer' || userRes.data.role == 'Procurement Assistant');
    }
    
    function isRequester(userId) {
      return isUserRole(userId, 'Requester');
    }
    
    function getDepartmentIdForUser(userId) {
        let userRes = getUserData(userId);
        if (userRes != null && 'departmentId' in userRes.data) {
            return userRes.data.departmentId;
        }
        return null;
    }

    function isAllowedToApprove(userId, requestData) {
      let userRes = getUserData(userId);
      if (userRes == null) {
        return false;
      }
      let userProfile = userRes.data;

      let isRequestManager = userProfile.role == 'Manager' && userProfile.departmentId == requestData.departmentId;
      let isRequestExecutive = isExecutiveWithPermission(userId, requestData.departmentId);

      if (requestData.status == 'Pending Manager Approval' || requestData.status == 'Queries Raised') {
        return isRequestManager || isRequestExecutive;
      }
      if (requestData.status == 'Pending Executive') {
        return isRequestExecutive;
      }
      
      return false;
    }
    
    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // Admins can manage roles, companies, approval groups, and app metadata
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /companies/{companyId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /approvalGroups/{groupId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /app/metadata {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /departments/{departmentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Procurement Requests have complex rules
    match /procurementRequests/{procurementRequestId} {
      allow get: if request.auth != null && (
                   isAdmin()
                   || isProcurementOfficer(request.auth.uid)
                   || isExecutiveWithPermission(request.auth.uid, resource.data.departmentId)
                   || resource.data.submittedById == request.auth.uid
                   || ((isManager(request.auth.uid) || isRequester(request.auth.uid)) && resource.data.departmentId == getDepartmentIdForUser(request.auth.uid))
                 );
    
      allow list: if request.auth != null;

      allow create: if request.auth != null && request.resource.data.status == 'Draft' && request.resource.data.submittedById == request.auth.uid;

      allow update: if
        isAdmin()
        || (resource.data.submittedById == request.auth.uid &&
            (resource.data.status == 'Draft' || resource.data.status == 'Queries Raised'))
        || isAllowedToApprove(request.auth.uid, resource.data)
        || (request.resource.data.delegatorIdForApproval != null &&
            getUserData(request.resource.data.delegatorIdForApproval) != null &&
            getUserData(request.resource.data.delegatorIdForApproval).data.delegatedToId == request.auth.uid &&
            isAllowedToApprove(request.resource.data.delegatorIdForApproval, resource.data))
        || (isProcurementOfficer(request.auth.uid) &&
            (resource.data.status == 'Approved' || resource.data.status == 'In Fulfillment'));

      allow delete: if isAdmin();
    }

    // Recurring Items
    match /recurringItems/{itemId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isProcurementOfficer(request.auth.uid) || isManager(request.auth.uid) || isRequester(request.auth.uid);
    }

    // Vendors
    match /vendors/{vendorId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isProcurementOfficer(request.auth.uid);
    }
    
    // Budget Data
    match /budgetUploads/{uploadId} {
      allow read, write: if isAdmin() || isProcurementOfficer(request.auth.uid);
    }
    match /budgets/{budgetId} {
      allow read, write: if isAdmin() || isProcurementOfficer(request.auth.uid);
    }

    // Logs can only be written by the app/user, and only read by Admins.
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
    }
    
    match /errorLogs/{errorLogId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
    }
    
    match /_diagnostics/{docId} {
      allow write: if request.auth != null;
    }
  }
}

    