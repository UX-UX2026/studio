{
  "entities": {
    "procurementRequest": {
      "title": "Procurement Request",
      "description": "Represents a request for procuring goods or services for a specific period.",
      "type": "object",
      "properties": {
        "department": {
          "type": "string",
          "description": "The department name requesting the procurement."
        },
        "departmentId": {
          "type": "string",
          "description": "The ID of the department requesting the procurement."
        },
        "period": {
          "type": "string",
          "description": "The period for which the procurement is requested (e.g., 'Feb 2026')."
        },
        "total": {
          "type": "number",
          "description": "The total value of the procurement request."
        },
        "status": {
          "type": "string",
          "enum": [
            "Pending Manager Approval",
            "Pending Executive",
            "Approved",
            "In Fulfillment",
            "Completed",
            "Queries Raised",
            "Rejected",
            "Draft"
          ],
          "description": "The current status of the approval workflow."
        },
        "submittedBy": {
          "type": "string",
          "description": "The name of the user who submitted the request."
        },
        "submittedById": {
          "type": "string",
          "description": "The UID of the user who submitted the request."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the request was created."
        },
        "timeline": {
          "type": "array",
          "description": "An ordered list of stages and their status in the approval process.",
          "items": {
            "type": "object",
            "properties": {
              "stage": {
                "type": "string"
              },
              "actor": {
                "type": "string"
              },
              "date": {
                "type": "string",
                "nullable": true
              },
              "status": {
                "type": "string",
                "enum": [
                  "completed",
                  "pending",
                  "waiting"
                ]
              }
            }
          }
        },
        "comments": {
          "type": "array",
          "description": "A log of comments and queries related to the request.",
          "items": {
            "type": "object",
            "properties": {
              "actor": {
                "type": "string"
              },
              "actorId": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "timestamp": {
                "type": "string"
              }
            }
          }
        },
        "items": {
          "type": "array",
          "description": "The list of individual items being procured.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "type": {
                "type": "string",
                "enum": [
                  "Recurring",
                  "One-Off"
                ]
              },
              "description": {
                "type": "string"
              },
              "brand": {
                "type": "string"
              },
              "qty": {
                "type": "number"
              },
              "category": {
                "type": "string"
              },
              "unitPrice": {
                "type": "number"
              },
              "fulfillmentStatus": {
                "type": "string",
                "enum": [
                  "Pending",
                  "Sourcing",
                  "Quoted",
                  "Ordered",
                  "Completed"
                ]
              },
              "receivedQty": {
                "type": "number"
              },
              "fulfillmentComments": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "required": [
        "department",
        "departmentId",
        "period",
        "total",
        "status",
        "submittedById",
        "timeline",
        "items",
        "createdAt"
      ]
    },
    "userProfile": {
      "title": "User Profile",
      "description": "Stores public information about a user.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "photoURL": {
          "type": "string",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "description": "The user's role in the application, which determines their permissions."
        },
        "department": {
          "type": "string",
          "description": "The name of the department this user belongs to or manages."
        },
        "status": {
          "type": "string",
          "enum": [
            "Active",
            "Invited"
          ],
          "description": "The current status of the user account."
        }
      },
      "required": [
        "displayName",
        "email",
        "role",
        "status"
      ]
    },
    "department": {
      "title": "Department",
      "description": "Represents a department within the organization.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the department."
        },
        "managerId": {
          "type": "string",
          "description": "The UID of the user who manages this department."
        },
        "budget": {
          "type": "number",
          "description": "The approved budget for the department."
        },
        "workflow": {
          "type": "array",
          "description": "An ordered list of stages and their permissions for this department's approval process.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "permissions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "capture",
                    "submit",
                    "review",
                    "comment",
                    "approve",
                    "lock",
                    "process",
                    "monitor"
                  ]
                }
              }
            },
            "required": [
              "id",
              "name",
              "role",
              "permissions"
            ]
          }
        }
      },
      "required": [
        "name"
      ]
    },
    "role": {
      "title": "Role",
      "description": "Defines a user role within the application.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the role."
        }
      },
      "required": [
        "name"
      ]
    },
    "vendor": {
      "title": "Vendor",
      "description": "Represents a supplier of goods or services.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The official name of the vendor."
        },
        "contactPerson": {
          "type": "string",
          "description": "The primary contact person at the vendor."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The contact email for the vendor."
        },
        "phone": {
          "type": "string",
          "description": "The contact phone number for the vendor."
        },
        "address": {
          "type": "string",
          "description": "The physical or mailing address of the vendor."
        },
        "category": {
          "type": "string",
          "description": "The primary category of goods/services the vendor provides (e.g., 'IT Hardware', 'Office Supplies')."
        },
        "status": {
          "type": "string",
          "enum": [
            "Active",
            "Inactive"
          ],
          "description": "The current status of the vendor."
        }
      },
      "required": [
        "name",
        "email",
        "category",
        "status"
      ]
    },
    "recurringItem": {
      "title": "Recurring Item",
      "description": "Defines a procurement item that recurs on a schedule.",
      "type": "object",
      "properties": {
        "category": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "nextLoad": {
          "type": "string"
        },
        "active": {
          "type": "boolean"
        },
        "frequency": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "category",
        "amount",
        "active",
        "frequency"
      ]
    },
    "appMetadata": {
      "title": "Application Metadata",
      "description": "Stores global application settings.",
      "type": "object",
      "properties": {
        "adminIsSetUp": {
          "type": "boolean",
          "description": "Flag to indicate if the first administrator has been created."
        }
      }
    },
    "auditEvent": {
      "title": "Audit Event",
      "description": "Records a single significant action taken by a user within the application.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who performed the action."
        },
        "userName": {
          "type": "string",
          "description": "The display name of the user."
        },
        "action": {
          "type": "string",
          "description": "A key identifying the action, e.g., 'user.login', 'request.create'."
        },
        "entity": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "description": "The type of entity affected, e.g., 'procurementRequest'."
            },
            "id": {
              "type": "string",
              "description": "The ID of the affected entity document."
            }
          }
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The server timestamp when the event was recorded."
        },
        "details": {
          "type": "string",
          "description": "A human-readable description of the action."
        }
      },
      "required": [
        "userId",
        "userName",
        "action",
        "timestamp"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ],
    "claims": {
      "role": {
        "type": "string",
        "description": "The user's role in the application, which determines their permissions."
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/userProfile"
      },
      "description": "Stores user profile information."
    },
    "/departments/{departmentId}": {
      "schema": {
        "$ref": "#/entities/department"
      },
      "description": "Collection of all departments."
    },
    "/roles/{roleId}": {
      "schema": {
        "$ref": "#/entities/role"
      },
      "description": "Collection of all user roles."
    },
    "/procurementRequests/{procurementRequestId}": {
      "schema": {
        "$ref": "#/entities/procurementRequest"
      },
      "description": "Collection of all procurement requests."
    },
    "/vendors/{vendorId}": {
      "schema": {
        "$ref": "#/entities/vendor"
      },
      "description": "Collection of all approved vendors and suppliers."
    },
    "/recurringItems/{recurringItemId}": {
      "schema": {
        "$ref": "#/entities/recurringItem"
      },
      "description": "Collection of all recurring procurement items."
    },
    "/app/metadata": {
      "schema": {
        "$ref": "#/entities/appMetadata"
      },
      "description": "Global application metadata."
    },
    "/auditLogs/{logId}": {
      "schema": {
        "$ref": "#/entities/auditEvent"
      },
      "description": "Collection of all audit trail events for tracking user actions."
    }
  }
}
