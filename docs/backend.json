{
  "entities": {
    "procurementRequest": {
      "title": "Procurement Request",
      "description": "Represents a request for procuring goods or services.",
      "type": "object",
      "properties": {
        "itemName": {
          "type": "string",
          "description": "The name of the item to be procured."
        },
        "itemDescription": {
          "type": "string",
          "description": "A detailed description of the item."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of the item requested."
        },
        "category": {
          "type": "string",
          "description": "The procurement category of the item."
        },
        "unitPrice": {
          "type": "number",
          "description": "The estimated or last known unit price of the item."
        },
        "department": {
          "type": "string",
          "description": "The department requesting the item."
        },
        "historicalPreviousVendors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "historicalAverageLeadTimeDays": {
          "type": "number"
        },
        "historicalAverageCost": {
          "type": "number"
        }
      },
      "required": [
        "itemName",
        "itemDescription",
        "quantity",
        "category",
        "department"
      ]
    },
    "userProfile": {
      "title": "User Profile",
      "description": "Stores public information about a user.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "photoURL": {
          "type": "string",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "enum": [
            "Administrator",
            "Manager",
            "Procurement Officer",
            "Executive"
          ]
        },
        "departmentId": {
          "type": "string",
          "description": "The ID of the department this user belongs to or manages."
        }
      },
      "required": [
        "displayName",
        "email",
        "role"
      ]
    },
    "department": {
      "title": "Department",
      "description": "Represents a department within the organization.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the department."
        },
        "managerId": {
          "type": "string",
          "description": "The UID of the user who manages this department."
        }
      },
      "required": [
        "name"
      ]
    },
    "workflow": {
      "title": "Approval Workflow",
      "description": "Defines the stages and permissions for the procurement approval process.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the workflow."
        },
        "stages": {
          "type": "array",
          "description": "An ordered list of stages in the workflow.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "The name of the stage (e.g., 'Manager Review')."
              },
              "role": {
                "type": "string",
                "description": "The user role responsible for this stage.",
                "enum": [
                  "Administrator",
                  "Manager",
                  "Procurement Officer",
                  "Executive"
                ]
              },
              "permissions": {
                "type": "array",
                "description": "A list of actions the user can perform at this stage.",
                "items": {
                  "type": "string",
                  "enum": [
                    "capture",
                    "submit",
                    "review",
                    "comment",
                    "approve",
                    "lock",
                    "process",
                    "monitor"
                  ]
                }
              }
            },
            "required": [
              "name",
              "role",
              "permissions"
            ]
          }
        }
      },
      "required": [
        "name",
        "stages"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ],
    "claims": {
      "role": {
        "type": "string",
        "description": "The user's role in the application, which determines their permissions.",
        "enum": [
          "Administrator",
          "Manager",
          "Procurement Officer",
          "Executive"
        ]
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/userProfile"
      },
      "description": "Stores user profile information."
    },
    "/departments/{departmentId}": {
      "schema": {
        "$ref": "#/entities/department"
      },
      "description": "Collection of all departments."
    },
    "/procurementRequests/{procurementRequestId}": {
      "schema": {
        "$ref": "#/entities/procurementRequest"
      },
      "description": "Collection of all procurement requests."
    },
    "/workflows/{workflowId}": {
      "schema": {
        "$ref": "#/entities/workflow"
      },
      "description": "Stores defined approval workflows."
    }
  }
}
